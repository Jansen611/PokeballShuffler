<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.w3.org/1999/xaml"
             xmlns:vm="clr-namespace:PokeballShuffler.ViewModels"
             x:Class="PokeballShuffler.MainPage"
             BackgroundColor="#1a1a2e">

    <Grid ColumnDefinitions="*,Auto"
          RowDefinitions="*"
          Padding="16">

        <!-- Left side: 4 Baskets in a HorizontalStackLayout -->
        <HorizontalStackLayout Grid.Column="0"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Spacing="16">

            <!-- Basket 1 -->
            <Frame BackgroundColor="#16213e"
                   CornerRadius="12"
                   Padding="12"
                   BorderColor="#0f3460"
                   BorderWidth="1"
                   WidthRequest="160">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Basket 1"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#e94560"
                           HorizontalOptions="Center" />
                    <Label Text="4 balls"
                           FontSize="10"
                           TextColor="#a0a0a0"
                           HorizontalOptions="Center" />
                    <VerticalStackLayout x:Name="Basket1Container"
                                         Spacing="6"
                                         Padding="4" />
                </VerticalStackLayout>
            </Frame>

            <!-- Basket 2 -->
            <Frame BackgroundColor="#16213e"
                   CornerRadius="12"
                   Padding="12"
                   BorderColor="#0f3460"
                   BorderWidth="1"
                   WidthRequest="160">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Basket 2"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#e94560"
                           HorizontalOptions="Center" />
                    <Label Text="3 balls"
                           FontSize="10"
                           TextColor="#a0a0a0"
                           HorizontalOptions="Center" />
                    <VerticalStackLayout x:Name="Basket2Container"
                                         Spacing="6"
                                         Padding="4" />
                </VerticalStackLayout>
            </Frame>

            <!-- Basket 3 -->
            <Frame BackgroundColor="#16213e"
                   CornerRadius="12"
                   Padding="12"
                   BorderColor="#0f3460"
                   BorderWidth="1"
                   WidthRequest="160">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Basket 3"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#e94560"
                           HorizontalOptions="Center" />
                    <Label Text="2 balls"
                           FontSize="10"
                           TextColor="#a0a0a0"
                           HorizontalOptions="Center" />
                    <VerticalStackLayout x:Name="Basket3Container"
                                         Spacing="6"
                                         Padding="4" />
                </VerticalStackLayout>
            </Frame>

            <!-- Basket 4 -->
            <Frame BackgroundColor="#16213e"
                   CornerRadius="12"
                   Padding="12"
                   BorderColor="#0f3460"
                   BorderWidth="1"
                   WidthRequest="160">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Basket 4"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#e94560"
                           HorizontalOptions="Center" />
                    <Label Text="1 ball"
                           FontSize="10"
                           TextColor="#a0a0a0"
                           HorizontalOptions="Center" />
                    <VerticalStackLayout x:Name="Basket4Container"
                                         Spacing="6"
                                         Padding="4" />
                </VerticalStackLayout>
            </Frame>
        </HorizontalStackLayout>

        <!-- Right side: Undrawn area + Buttons -->
        <VerticalStackLayout Grid.Column="1"
                            VerticalOptions="Center"
                            Spacing="24"
                            Padding="24,0,0,0"
                            WidthRequest="220">

            <!-- Undrawn Balls area -->
            <Frame BackgroundColor="#0f3460"
                   CornerRadius="12"
                   Padding="12"
                   BorderColor="#e94560"
                   BorderWidth="1">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Undrawn"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#e94560"
                           HorizontalOptions="Center" />
                    <Label Text="5 remaining"
                           FontSize="10"
                           TextColor="#a0a0a0"
                           HorizontalOptions="Center" />
                    <VerticalStackLayout x:Name="UndrawnContainer"
                                        Spacing="4"
                                        Padding="4" />
                </VerticalStackLayout>
            </Frame>

            <!-- Round indicator -->
            <Label x:Name="RoundLabel"
                   Text="Round 1 of 4"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#ffffff"
                   HorizontalOptions="Center" />

            <!-- Shuffle Button -->
            <Button x:Name="ShuffleBtn"
                    Text="SHUFFLE"
                    FontSize="22"
                    FontAttributes="Bold"
                    BackgroundColor="#e94560"
                    TextColor="#ffffff"
                    CornerRadius="12"
                    HeightRequest="60"
                    Clicked="OnShuffleClicked" />

            <!-- Reset Button -->
            <Button x:Name="ResetBtn"
                    Text="RESET"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#0f3460"
                    TextColor="#a0a0a0"
                    CornerRadius="12"
                    HeightRequest="50"
                    IsEnabled="False"
                    Clicked="OnResetClicked" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
