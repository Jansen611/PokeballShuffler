{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Android APK (Debug)",
            "type": "shell",
            "command": "dotnet build PokeballShuffler/PokeballShuffler.csproj -f net9.0-android -c Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Android APK (Release)",
            "type": "shell",
            "command": "dotnet build PokeballShuffler/PokeballShuffler.csproj -f net9.0-android -c Release",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Install APK to Android Device",
            "type": "shell",
            "command": "adb -s \"adb-BPADSE2503006240-GrfEiQ._adb-tls-connect._tcp\" install -r \"PokeballShuffler/bin/Release/net9.0-android/com.companyname.pokeballshuffler-Signed.apk\"",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Install APK (Release)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Android APK (Release)",
                "Install APK to Android Device"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
